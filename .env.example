# Copy to .env for local testing:  cp .env.example .env
# (.env is gitignored — never commit real secrets.)

TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token-from-BotFather
TELEGRAM_CHAT_ID=your-numeric-chat-id
ANTHROPIC_API_KEY=sk-ant-your-key

# Optional:
# ANTHROPIC_MODEL=claude-opus-4-8        # default; set claude-haiku-4-5 to cut cost
# RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY   # recommended over public RPC
# DRY_RUN=1                               # print alerts instead of sending to Telegram
